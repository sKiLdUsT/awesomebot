<% include helper/license.ejs %>
<!DOCTYPE html>
<html lang="en">
<% include helper/head.ejs %>
<body>
    <% include helper/navigation.ejs %>
    <div class="container full-height d-flex justify-content-center">
        <div class="align-self-center">
            <% if (!user) { %>
                <div class="card p-10">
                    <h4 class="card-header">Welcome</h4>
                    <div class="card-body p-3">
                        <p>It seems like we've never met before.</p>
                        <p>
                            Why don't you go ahead and
                            <a href="/login">authenticate yourself</a>
                            so I know who you are?
                        </p>
                   </div>
                </div>
            <% } else { %>
                <div class="card">
                    <h4 class="card-header">Hello <%= user.name %>!</h4>
                    <div class="card-body p-3">
                        <p>Manageable servers:</p>
                        <div class="row">
                            <% user.servers.forEach(server => { %>
                                <div class="col">
                                    <a class="btn btn-dark text-light" href="/manage/<%= server.id %>">
                                        <img class="nav-pic" src="<%= server.icon %>">
                                        <%= server.name %>
                                    </a>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js" integrity="sha384-q8i/X+965DzO0rT7abK41JStQIAqVgRVzpbzo5smXKp4YfRvH+8abtTE1Pi6jizo" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.3/umd/popper.min.js" integrity="sha384-ZMP7rVo3mIykV+2+9J3UJ46jBk0WLaUAdn689aCwoqbBJiSnjAK/l8WvCWPIPm49" crossorigin="anonymous"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/js/bootstrap.min.js" integrity="sha384-ChfqqxuZUCnJSK3+MXmPNIyE6ZbWh2IMqE241rYiqJxyMiZ6OW/JmZQ5stwEULTy" crossorigin="anonymous"></script>
    <script src="/res/js/app.js"></script>
</body>
</html>